rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['city', 'userId', 'createdAt']) 
        && data.keys().size() == 3
        && data.city is string && data.city.size() <= 100
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    match /users/{userId}/favorites/{cityId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(cityId)
        && isValidFavorite(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
